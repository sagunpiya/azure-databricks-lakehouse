    "gold_df = spark.sql(\"\"\"\n",
    "SELECT\n",
    "ProductName,\n",
    "SUM(Quantity) QuantitySold,\n",
    "SUM(Quantity * Price) Revenue\n",
    "FROM dev_sales.silver.orders\n",
    "GROUP BY ProductName\n",
    "\"\"\")\n",
    "\n",
    "gold_df.write \\\n",
    ".format(\"delta\") \\\n",
    ".mode(\"overwrite\") \\\n",
    ".saveAsTable(\n",
    "\"dev_sales.gold.orders_summary\"\n",
    ")"
   ]
  }
